@*
    Step 2 del wizard: esito complessivo (Sez. 2 PDF) + condizioni meteo +
    temperatura. Le interferenze (Sez. 7 PDF) sono nello step dedicato 7.

    Esito e Meteo sono richiesti per avanzare allo step 3 (regola wizard,
    non DB: in DB sono nullable per ammettere bozze parziali).
*@

@using ICMVerbali.Web.Entities
@using ICMVerbali.Web.Entities.Enums

<MudPaper Class="pa-6" Elevation="1">
    <MudText Typo="Typo.h6" GutterBottom="true">Sezione 2 — Esito e meteo</MudText>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Esito complessivo</MudText>
            <MudRadioGroup T="EsitoVerifica?" Value="_esito" ValueChanged="@((EsitoVerifica? e) => _esito = e)">
                <MudRadio T="EsitoVerifica?" Value="@((EsitoVerifica?)EsitoVerifica.Conforme)">Conforme</MudRadio>
                <MudRadio T="EsitoVerifica?" Value="@((EsitoVerifica?)EsitoVerifica.NcMinori)">Non conformità minori</MudRadio>
                <MudRadio T="EsitoVerifica?" Value="@((EsitoVerifica?)EsitoVerifica.NcGravi)">Non conformità gravi</MudRadio>
                <MudRadio T="EsitoVerifica?" Value="@((EsitoVerifica?)EsitoVerifica.Sospensione)">Sospensione attività</MudRadio>
            </MudRadioGroup>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Condizioni meteo</MudText>
            <MudRadioGroup T="CondizioneMeteo?" Value="_meteo" ValueChanged="@((CondizioneMeteo? m) => _meteo = m)">
                <MudRadio T="CondizioneMeteo?" Value="@((CondizioneMeteo?)CondizioneMeteo.Sereno)">Sereno</MudRadio>
                <MudRadio T="CondizioneMeteo?" Value="@((CondizioneMeteo?)CondizioneMeteo.Nuvoloso)">Nuvoloso</MudRadio>
                <MudRadio T="CondizioneMeteo?" Value="@((CondizioneMeteo?)CondizioneMeteo.Pioggia)">Pioggia</MudRadio>
                <MudRadio T="CondizioneMeteo?" Value="@((CondizioneMeteo?)CondizioneMeteo.Neve)">Neve</MudRadio>
            </MudRadioGroup>

            <MudNumericField T="int?" Label="Temperatura (°C)" Value="_temperatura"
                             ValueChanged="@((int? t) => _temperatura = t)"
                             Min="-30" Max="60" Class="mt-4" />
        </MudItem>
    </MudGrid>

    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="OnBack">
            Indietro
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(!IsValid() || _saving)"
                   OnClick="HandleSubmitAsync"
                   EndIcon="@Icons.Material.Filled.ArrowForward">
            Salva e prosegui
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public Verbale Existing { get; set; } = null!;
    [Parameter] public EventCallback<Step2Submission> OnSubmit { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private bool _saving;
    private EsitoVerifica? _esito;
    private CondizioneMeteo? _meteo;
    private int? _temperatura;

    protected override void OnInitialized()
    {
        _esito = Existing.Esito;
        _meteo = Existing.Meteo;
        _temperatura = Existing.TemperaturaCelsius;
    }

    private bool IsValid()
        => _esito.HasValue && _meteo.HasValue;

    private async Task HandleSubmitAsync()
    {
        if (!IsValid()) return;
        _saving = true;
        var submission = new Step2Submission(_esito, _meteo, _temperatura);
        await OnSubmit.InvokeAsync(submission);
        _saving = false;
    }

    public sealed record Step2Submission(
        EsitoVerifica? Esito,
        CondizioneMeteo? Meteo,
        int? TemperaturaCelsius);
}
