@*
    Step 9 del wizard: galleria foto della verifica (Sez. 9 PDF). UX target:
    smartphone in cantiere. Bottone full-width "Aggiungi foto" che apre il
    bottom-sheet nativo iOS/Android (camera + galleria + file). Optimistic UI:
    le card placeholder compaiono subito con spinner mentre l'upload + resize
    + thumb generation girano in background. Riordino con ↑ ↓ (drag-and-drop
    su mobile e' impreciso). Auto-save su blur per la didascalia.
*@

@using ICMVerbali.Web.Entities
@using ICMVerbali.Web.Managers.Interfaces
@using Microsoft.AspNetCore.Components.Forms

@inject IFotoManager FotoManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<WizardStep9Foto> Logger

<MudPaper Class="pa-6" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
        <MudText Typo="Typo.h6">Sezione 9 — Foto della verifica</MudText>
        <AutoSaveBadge Status="_autoSaveStatus" />
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Class="my-4" />
    }
    else
    {
        @* Due bottoni distinti via InputFile + label-for: Android 13+ Photo
           Picker non offre l'opzione fotocamera, quindi serve un input dedicato
           con capture="environment" per aprire la camera. L'input e' nascosto;
           il MudButton (HtmlTag=label, for=...) funge da activator stilizzato. *@
        <MudGrid Spacing="2" Class="mb-4">
            <MudItem xs="6">
                <InputFile id="foto-camera-input"
                           OnChange="HandleCameraInputChange"
                           accept="image/*"
                           capture="environment"
                           style="display: none;" />
                <MudButton HtmlTag="label"
                           for="foto-camera-input"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.PhotoCamera"
                           FullWidth="true"
                           Size="Size.Large">
                    Scatta
                </MudButton>
            </MudItem>
            <MudItem xs="6">
                <InputFile id="foto-gallery-input"
                           OnChange="HandleGalleryInputChange"
                           accept="image/*"
                           multiple
                           style="display: none;" />
                <MudButton HtmlTag="label"
                           for="foto-gallery-input"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.PhotoLibrary"
                           FullWidth="true"
                           Size="Size.Large">
                    Galleria
                </MudButton>
            </MudItem>
        </MudGrid>

        @if (_foto.Count == 0 && _uploads.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="my-4">
                Nessuna foto. Premi "Scatta" per usare la fotocamera o "Galleria" per scegliere foto già presenti.
            </MudAlert>
        }

        <MudGrid Spacing="2">
            @* Card foto gia' caricate *@
            @for (var i = 0; i < _foto.Count; i++)
            {
                var idx = i;
                var foto = _foto[idx];
                <MudItem xs="6" sm="4" md="3" @key="foto.Id">
                    <MudPaper Class="pa-2" Outlined="true">
                        <div style="position: relative; width: 100%; aspect-ratio: 1/1; overflow: hidden; background: var(--mud-palette-background-grey);">
                            <img src="@($"/api/foto/{foto.Id}/thumb")"
                                 alt="Foto @(idx + 1)"
                                 style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                        </div>
                        <MudTextField T="string"
                                      Value="foto.Didascalia"
                                      ValueChanged="@((string? d) => foto.Didascalia = d)"
                                      OnBlur="@(_ => SaveDidascaliaAsync(foto))"
                                      Label="Didascalia"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="mt-2" />
                        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-1">
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                                           Size="Size.Small"
                                           Disabled="@(idx == 0)"
                                           OnClick="@(() => MoveUpAsync(idx))"
                                           title="Sposta su" />
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward"
                                           Size="Size.Small"
                                           Disabled="@(idx == _foto.Count - 1)"
                                           OnClick="@(() => MoveDownAsync(idx))"
                                           title="Sposta giu" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => DeleteAsync(foto))"
                                           title="Elimina" />
                        </MudStack>
                    </MudPaper>
                </MudItem>
            }

            @* Placeholder cards per upload in corso *@
            @foreach (var up in _uploads)
            {
                <MudItem xs="6" sm="4" md="3" @key="up.ClientId">
                    <MudPaper Class="pa-2" Outlined="true">
                        <div style="position: relative; width: 100%; aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; background: var(--mud-palette-background-grey);">
                            @if (up.Status == UploadStatus.InProgress)
                            {
                                <MudProgressCircular Indeterminate="true" />
                            }
                            else if (up.Status == UploadStatus.Failed)
                            {
                                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" />
                                    <MudButton Size="Size.Small"
                                               Variant="Variant.Text"
                                               OnClick="@(() => RetryAsync(up))"
                                               StartIcon="@Icons.Material.Filled.Refresh">
                                        Riprova
                                    </MudButton>
                                </MudStack>
                            }
                        </div>
                        <MudText Typo="Typo.caption" Class="mt-2 d-block text-truncate">@up.FileName</MudText>
                        @if (up.Status == UploadStatus.Failed && !string.IsNullOrEmpty(up.ErrorMessage))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error">@up.ErrorMessage</MudText>
                        }
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
            <MudButton Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="OnBack">
                Indietro
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="OnSubmit"
                       EndIcon="@Icons.Material.Filled.ArrowForward">
                Prosegui al riepilogo
            </MudButton>
        </MudStack>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public Guid VerbaleId { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private bool _loading = true;
    private AutoSaveStatus _autoSaveStatus = AutoSaveStatus.Idle;
    private List<Foto> _foto = new();
    private List<UploadItem> _uploads = new();

    private const int MaxGalleryFiles = 20;

    protected override async Task OnInitializedAsync()
    {
        var rows = await FotoManager.GetByVerbaleAsync(VerbaleId);
        _foto = rows.ToList();
        _loading = false;
    }

    // Camera (capture="environment"): un solo file alla volta.
    private Task HandleCameraInputChange(InputFileChangeEventArgs e)
        => ProcessIncomingAsync("camera", e.FileCount == 0 ? null : new[] { e.File });

    // Galleria (multiple): 1..N file. Processati in serie per resilienza.
    private Task HandleGalleryInputChange(InputFileChangeEventArgs e)
        => ProcessIncomingAsync("galleria", e.FileCount == 0 ? null : e.GetMultipleFiles(MaxGalleryFiles));

    private async Task ProcessIncomingAsync(string source, IReadOnlyList<IBrowserFile>? files)
    {
        if (files is null || files.Count == 0) return;

        // Log diagnostico utile per testare device diversi (es. iPhone HEIC vs
        // Android JPEG): una riga per file con name/size/contentType.
        foreach (var f in files)
        {
            Logger.LogInformation(
                "[FOTO] upload da {Source}: name={Name} size={Size}B type={Type}",
                source, f.Name, f.Size, f.ContentType);
        }

        // Aggiungi placeholder cards subito (optimistic UI).
        var newUploads = files.Select(f => new UploadItem
        {
            ClientId = Guid.NewGuid(),
            BrowserFile = f,
            FileName = f.Name,
            Status = UploadStatus.InProgress,
        }).ToList();
        _uploads.AddRange(newUploads);
        StateHasChanged();

        foreach (var up in newUploads)
        {
            await ProcessUploadAsync(up);
        }
    }

    private async Task ProcessUploadAsync(UploadItem up)
    {
        try
        {
            await using var stream = up.BrowserFile.OpenReadStream(
                maxAllowedSize: 16L * 1024 * 1024);

            var foto = await FotoManager.UploadAsync(
                VerbaleId, stream, up.BrowserFile.Name, up.BrowserFile.Size);

            _foto.Add(foto);
            _uploads.Remove(up);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[FOTO] Upload failed per {Name}", up.FileName);
            up.Status = UploadStatus.Failed;
            up.ErrorMessage = ex.Message.Length > 80 ? ex.Message[..80] + "…" : ex.Message;
            StateHasChanged();
        }
    }

    private async Task RetryAsync(UploadItem up)
    {
        up.Status = UploadStatus.InProgress;
        up.ErrorMessage = null;
        StateHasChanged();
        await ProcessUploadAsync(up);
    }

    private async Task SaveDidascaliaAsync(Foto foto)
    {
        _autoSaveStatus = AutoSaveStatus.Saving;
        StateHasChanged();
        try
        {
            await FotoManager.UpdateDidascaliaAsync(foto.Id, foto.Didascalia);
            _autoSaveStatus = AutoSaveStatus.Saved;
        }
        catch
        {
            _autoSaveStatus = AutoSaveStatus.Error;
        }
    }

    private async Task MoveUpAsync(int idx)
    {
        if (idx <= 0 || idx >= _foto.Count) return;
        (_foto[idx - 1], _foto[idx]) = (_foto[idx], _foto[idx - 1]);
        await PersistOrderAsync();
    }

    private async Task MoveDownAsync(int idx)
    {
        if (idx < 0 || idx >= _foto.Count - 1) return;
        (_foto[idx + 1], _foto[idx]) = (_foto[idx], _foto[idx + 1]);
        await PersistOrderAsync();
    }

    private async Task PersistOrderAsync()
    {
        _autoSaveStatus = AutoSaveStatus.Saving;
        StateHasChanged();
        try
        {
            await FotoManager.ReorderAsync(VerbaleId, _foto.Select(f => f.Id).ToList());
            _autoSaveStatus = AutoSaveStatus.Saved;
        }
        catch
        {
            _autoSaveStatus = AutoSaveStatus.Error;
        }
    }

    private async Task DeleteAsync(Foto foto)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(new MudBlazor.MessageBoxOptions
        {
            Title = "Eliminare la foto?",
            Message = "Operazione non annullabile.",
            YesText = "Elimina",
            CancelText = "Annulla",
        });
        if (confirm != true) return;

        try
        {
            await FotoManager.DeleteAsync(foto.Id);
            _foto.Remove(foto);
            Snackbar.Add("Foto eliminata.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    private sealed class UploadItem
    {
        public Guid ClientId { get; set; }
        public IBrowserFile BrowserFile { get; set; } = null!;
        public string FileName { get; set; } = string.Empty;
        public UploadStatus Status { get; set; }
        public string? ErrorMessage { get; set; }
    }

    private enum UploadStatus
    {
        InProgress,
        Failed,
    }
}
