@*
    Step 9 del wizard: galleria foto della verifica (Sez. 9 PDF).
    In B.8d e' un placeholder: l'upload reale + persistenza via IFotoStorageService
    arrivera' nella sotto-fase B.9.
*@

<MudPaper Class="pa-6" Elevation="1">
    <MudText Typo="Typo.h6" GutterBottom="true">Sezione 9 — Foto della verifica</MudText>

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="my-4">
        <MudText>
            <strong>In costruzione (B.9).</strong> L'upload e la gestione delle foto
            (galleria, didascalie, riordino) sono pianificati per la prossima sotto-fase.
            Per ora puoi proseguire al riepilogo.
        </MudText>
    </MudAlert>

    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-6">
        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="OnBack">
            Indietro
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="OnSubmit"
                   EndIcon="@Icons.Material.Filled.ArrowForward">
            Prosegui al riepilogo
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    [Parameter] public EventCallback OnSubmit { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }
}
