@page "/verbali/nuovo"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Nuovo verbale — ICMVerbali</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="1">
        <MudText Typo="Typo.h5" GutterBottom="true">Wizard verbale</MudText>
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">
            Il wizard di creazione verbale verrà implementato in B.8b.
            Per ora questa è una pagina segnaposto raggiungibile dal pulsante "+" della Home.
        </MudAlert>
        <MudButton Variant="Variant.Text" Href="/" Class="mt-4">Torna alla Home</MudButton>
    </MudPaper>
</MudContainer>
