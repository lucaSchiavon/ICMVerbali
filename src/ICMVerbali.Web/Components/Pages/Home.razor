@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@using ICMVerbali.Web.Entities.Enums
@using ICMVerbali.Web.Managers.Interfaces
@using ICMVerbali.Web.Models
@inject IVerbaleManager VerbaleManager
@inject NavigationManager Nav

<PageTitle>Home — ICMVerbali</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <AuthorizeView>
        <Authorized>
            <MudText Typo="Typo.h4" GutterBottom="true">
                Benvenuto, @context.User.Identity?.Name
            </MudText>
            <MudText Typo="Typo.subtitle1" Class="mb-6 mud-text-secondary">
                @_oggi.ToString("dddd d MMMM yyyy")
            </MudText>

            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.h6" GutterBottom="true">Verbali di oggi</MudText>
                        @if (_loading)
                        {
                            <MudProgressLinear Indeterminate="true" Class="my-4" />
                        }
                        else if (_verbaliOggi.Count == 0)
                        {
                            <MudText Class="mud-text-secondary">Nessun verbale registrato oggi.</MudText>
                        }
                        else
                        {
                            <MudList T="VerbaleListItem" Dense="true">
                                @foreach (var v in _verbaliOggi)
                                {
                                    var id = v.Id;
                                    var stato = v.Stato;
                                    <MudListItem T="VerbaleListItem" Icon="@Icons.Material.Filled.Description"
                                                 OnClick="@(() => OpenVerbale(id, stato))">
                                        <MudText Typo="Typo.body1">
                                            <strong>@FormatNumero(v)</strong> — @v.CantiereUbicazione
                                        </MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            @v.ImpresaAppaltatriceRagioneSociale · @StatoLabel(v.Stato)
                                        </MudText>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.h6" GutterBottom="true">Bozze in corso</MudText>
                        @if (_loading)
                        {
                            <MudProgressLinear Indeterminate="true" Class="my-4" />
                        }
                        else if (_bozze.Count == 0)
                        {
                            <MudText Class="mud-text-secondary">Nessuna bozza in sospeso.</MudText>
                        }
                        else
                        {
                            <MudList T="VerbaleListItem" Dense="true">
                                @foreach (var v in _bozze)
                                {
                                    var id = v.Id;
                                    <MudListItem T="VerbaleListItem" Icon="@Icons.Material.Filled.EditNote"
                                                 OnClick="@(() => OpenWizard(id))">
                                        <MudText Typo="Typo.body1">
                                            <strong>@v.CantiereUbicazione</strong>
                                        </MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            Data: @v.Data.ToString("dd/MM/yyyy") · ultima modifica @v.UpdatedAt.ToLocalTime().ToString("dd/MM HH:mm")
                                        </MudText>
                                    </MudListItem>
                                }
                            </MudList>
                            @* Le bozze aprono sempre il wizard, non la detail view. *@
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudFab Color="Color.Primary"
                    StartIcon="@Icons.Material.Filled.Add"
                    Style="position: fixed; bottom: 32px; right: 32px;"
                    OnClick="@(() => Nav.NavigateTo("/verbali/nuovo"))"
                    aria-label="Nuovo verbale" />
        </Authorized>
    </AuthorizeView>
</MudContainer>

@code {
    private readonly DateOnly _oggi = DateOnly.FromDateTime(DateTime.Now);
    private bool _loading = true;
    private IReadOnlyList<VerbaleListItem> _verbaliOggi = Array.Empty<VerbaleListItem>();
    private IReadOnlyList<VerbaleListItem> _bozze = Array.Empty<VerbaleListItem>();

    protected override async Task OnInitializedAsync()
    {
        var oggiTask = VerbaleManager.GetVerbaliDelGiornoAsync(_oggi);
        var bozzeTask = VerbaleManager.GetBozzeAsync();
        await Task.WhenAll(oggiTask, bozzeTask);
        _verbaliOggi = oggiTask.Result;
        _bozze = bozzeTask.Result;
        _loading = false;
    }

    private void OpenWizard(Guid verbaleId)
        => Nav.NavigateTo($"/verbali/{verbaleId}/step/1");

    // I verbali in Bozza si aprono nel wizard (per continuarne la compilazione);
    // quelli con Stato >= FirmatoCse si aprono nella detail view read-only (B.11).
    private void OpenVerbale(Guid verbaleId, StatoVerbale stato)
    {
        if (stato == StatoVerbale.Bozza)
            Nav.NavigateTo($"/verbali/{verbaleId}/step/1");
        else
            Nav.NavigateTo($"/verbali/{verbaleId}");
    }

    private static string FormatNumero(VerbaleListItem v)
        => v.Numero.HasValue && v.Anno.HasValue
            ? $"VERBALE N. {v.Numero}/{v.Anno}"
            : "VERBALE";

    private static string StatoLabel(StatoVerbale stato) => stato switch
    {
        StatoVerbale.Bozza => "bozza",
        StatoVerbale.FirmatoCse => "firmato CSE",
        StatoVerbale.FirmatoImpresa => "firmato Impresa",
        StatoVerbale.Chiuso => "chiuso",
        _ => stato.ToString(),
    };
}
