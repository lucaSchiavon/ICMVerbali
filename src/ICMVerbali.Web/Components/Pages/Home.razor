@page "/"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Home — ICMVerbali</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <AuthorizeView>
        <Authorized>
            <MudText Typo="Typo.h4" GutterBottom="true">
                Benvenuto, @context.User.Identity?.Name
            </MudText>
            <MudText Typo="Typo.body1" Class="mb-4">
                La lista verbali del giorno e il pulsante "+" verranno aggiunti in B.8.
            </MudText>
        </Authorized>
    </AuthorizeView>
</MudContainer>
