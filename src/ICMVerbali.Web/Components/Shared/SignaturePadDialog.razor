@*
    Dialog di firma CSE. Carica dinamicamente /js/signatureInterop.js (ES module),
    monta un signature_pad su un canvas, raccoglie il PNG come data URL, lo
    converte in byte[] e chiama VerbaleManager.FirmaCseAsync.

    Errori di validazione (anagrafica/esito/meteo mancanti) tornano come
    VerbaleNonFirmabileException con lista puntuale: la mostriamo in un MudAlert
    dentro il dialog senza chiuderlo, cosi' l'utente capisce cosa correggere.

    Su successo: chiude il dialog passando il (Numero, Anno) assegnato.
*@

@using System.Security.Claims
@using ICMVerbali.Web.Managers
@using ICMVerbali.Web.Managers.Interfaces
@using ICMVerbali.Web.Repositories.Interfaces

@inject IVerbaleManager VerbaleManager
@inject IJSRuntime JS
@implements IAsyncDisposable

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.Verified" Class="mr-2" />Firma CSE</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_nomeFirmatario"
                          Label="Nome del firmatario (CSE)"
                          Variant="Variant.Outlined"
                          Required="true"
                          Disabled="_signing"
                          MaxLength="200" />

            <div>
                <MudText Typo="Typo.body2" Class="mb-1 mud-text-secondary">
                    Disegna la firma nel riquadro qui sotto.
                </MudText>
                <div style="border: 1px solid var(--mud-palette-lines-default); border-radius: 4px; background: #fff; touch-action: none;">
                    <canvas id="@_canvasId"
                            style="display: block; width: 100%; height: 200px; touch-action: none;"></canvas>
                </div>
            </div>

            @if (_validationErrors is { Count: > 0 })
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                    <MudText Typo="Typo.body2"><strong>Impossibile firmare:</strong></MudText>
                    <ul class="mt-1 mb-0" style="padding-left: 1.2em;">
                        @foreach (var err in _validationErrors)
                        {
                            <li>@err</li>
                        }
                    </ul>
                </MudAlert>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                    @_errorMessage
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="HandleClearAsync" Disabled="_signing"
                   StartIcon="@Icons.Material.Filled.Refresh">
            Pulisci
        </MudButton>
        <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="_signing">
            Annulla
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success"
                   OnClick="HandleConfirmAsync"
                   Disabled="_signing || string.IsNullOrWhiteSpace(_nomeFirmatario)"
                   StartIcon="@Icons.Material.Filled.Check">
            @(_signing ? "Firma in corso..." : "Conferma firma")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = null!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = null!;

    [Parameter, EditorRequired] public Guid VerbaleId { get; set; }
    [Parameter] public string NomeFirmatarioSuggerito { get; set; } = string.Empty;

    private readonly string _canvasId = $"sig-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private string _nomeFirmatario = string.Empty;
    private bool _signing;
    private string? _errorMessage;
    private IReadOnlyList<string>? _validationErrors;

    protected override void OnInitialized()
    {
        _nomeFirmatario = NomeFirmatarioSuggerito ?? string.Empty;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "/js/signatureInterop.js");
            await _module.InvokeVoidAsync("init", _canvasId, new
            {
                backgroundColor = "rgb(255,255,255)",
                penColor = "rgb(0,0,0)",
            });
        }
        catch (Exception ex)
        {
            _errorMessage = $"Impossibile inizializzare l'area di firma: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task HandleClearAsync()
    {
        if (_module is null) return;
        await _module.InvokeVoidAsync("clear", _canvasId);
        _errorMessage = null;
    }

    private void Cancel() => Dialog.Cancel();

    private async Task HandleConfirmAsync()
    {
        _errorMessage = null;
        _validationErrors = null;

        if (_module is null)
        {
            _errorMessage = "Area di firma non pronta.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_nomeFirmatario))
        {
            _errorMessage = "Inserisci il nome del firmatario.";
            return;
        }

        var isEmpty = await _module.InvokeAsync<bool>("isEmpty", _canvasId);
        if (isEmpty)
        {
            _errorMessage = "Disegna la firma prima di confermare.";
            return;
        }

        string? dataUrl;
        try
        {
            dataUrl = await _module.InvokeAsync<string?>("getDataUrl", _canvasId, "image/png");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Errore lettura firma: {ex.Message}";
            return;
        }
        if (string.IsNullOrEmpty(dataUrl))
        {
            _errorMessage = "Firma vuota.";
            return;
        }

        const string prefix = "data:image/png;base64,";
        if (!dataUrl.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
        {
            _errorMessage = "Formato firma non valido.";
            return;
        }
        byte[] pngBytes;
        try
        {
            pngBytes = Convert.FromBase64String(dataUrl[prefix.Length..]);
        }
        catch (FormatException)
        {
            _errorMessage = "Encoding firma non valido.";
            return;
        }

        var auth = await AuthStateTask;
        var utenteIdStr = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!Guid.TryParse(utenteIdStr, out var utenteId))
        {
            _errorMessage = "Utente non identificato. Effettua di nuovo il login.";
            return;
        }

        _signing = true;
        StateHasChanged();
        try
        {
            var result = await VerbaleManager.FirmaCseAsync(
                VerbaleId, _nomeFirmatario, pngBytes, utenteId);
            Dialog.Close(DialogResult.Ok(result));
        }
        catch (VerbaleNonFirmabileException vex)
        {
            _validationErrors = vex.Errori;
        }
        catch (InvalidOperationException iex)
        {
            _errorMessage = iex.Message;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Errore durante la firma: {ex.Message}";
        }
        finally
        {
            _signing = false;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose", _canvasId);
                await _module.DisposeAsync();
            }
            catch
            {
                // ignora errori in dispose (circuit gia' chiuso, ecc.)
            }
        }
    }
}
